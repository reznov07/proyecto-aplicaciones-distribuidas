# ── Dependencias ─────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Variables de entorno (nunca subir credenciales) ─────────────────
.env
.env.*
!.env.example

# ── Logs ─────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# ── Sistema operativo / editor ───────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Build / cache ────────────────────────────────────────────────────
dist/
build/
coverage/
.cache/

# ── Docker ───────────────────────────────────────────────────────────
*.pid

# ── Kubernetes: nunca subir secrets con valores reales ──────────────
k8s/**/secret*.local.yaml
k8s/**/*.secret.yaml
k8s/**/secrets.yaml

# ── Terraform / infra local, si se llega a usar ─────────────────────
*.tfstate
*.tfstate.*
.terraform/
